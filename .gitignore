# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual Environment folders
venv/
ENV/
.venv/

# SECURITY: Never commit real secrets to GitHub.
# Store secrets in Render dashboard → Environment tab.
# Only the template file (.env.example) is tracked.
env/.env
!env/.env.example

# Database files
database/*.db
database/test_phishing.db

# Logs
logs/
*.log

# Generated PDF reports
reports/generated/
reports/generated/*.pdf

# Temporary Uploads & Screenshots
static/uploads/*
!static/uploads/screenshots/
static/uploads/screenshots/*

# IDE configs
.vscode/
.idea/
.project
.pydevproject
.settings/

# OS files
.DS_Store
Thumbs.db

# Scratch and Temporary scripts
scratch/
