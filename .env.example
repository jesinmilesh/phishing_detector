# ==========================================
# AI SHIELD — ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to env/.env and fill in your values.
# NEVER commit env/.env to version control.

# Flask Secret Key
SECRET_KEY=change_this_to_a_secure_random_hex_in_production

# Debug mode (False in production)
DEBUG=False

# Port
PORT=5000

# Rate limiting
RATE_LIMIT=100 per hour

# ==========================================
# RESEND EMAIL API (Primary Email Provider)
# ==========================================
# 1. Sign up at https://resend.com and get your API key
# 2. Go to https://resend.com/api-keys → Create API key → copy it below
# 3. For production: verify your domain at https://resend.com/domains
#    then set RESEND_FROM_EMAIL to noreply@yourdomain.com
# 4. For local testing: leave RESEND_FROM_EMAIL as onboarding@resend.dev
#    NOTE: In test mode, Resend only delivers to your Resend account owner email.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender shown in "From:" field of every outgoing email
# Test mode:  AI Shield <onboarding@resend.dev>
# Production: AI Shield <noreply@yourdomain.com>
RESEND_FROM_EMAIL=AI Shield <onboarding@resend.dev>

# ==========================================
# SMTP FALLBACK (optional, for /test-email)
# ==========================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# ==========================================
# APPLICATION URL
# ==========================================
# Local development:
APP_BASE_URL=http://localhost:5000
# Production (example):
# APP_BASE_URL=https://aishield.yourdomain.com
PREFERRED_URL_SCHEME=http
