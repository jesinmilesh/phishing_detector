# ==========================================
# TR-PHISH ENVIRONMENT CONFIGURATION
# ==========================================

# Flask Secret Key for Session Cryptography and CSRF
SECRET_KEY=change_this_to_a_secure_random_hex_in_production

# Application Debug Mode (set to False in production)
DEBUG=False

# Port to bind the Flask web application
PORT=5000

# Rate limiting threshold (e.g., "100 per hour" or "5 per minute")
RATE_LIMIT="100 per hour"

# ==========================================
# SMTP EMAIL CONFIGURATION
# ==========================================
# The server address of your email provider (e.g. smtp.gmail.com)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True

# Your email address and App Password (not your main email password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ==========================================
# APPLICATION URL CONFIGURATION
# ==========================================
# Set this to the external URL where your app is hosted
APP_BASE_URL=http://localhost:5000
PREFERRED_URL_SCHEME=http
